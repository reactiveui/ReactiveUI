<?xml version="1.0" encoding="utf-8" ?>
<rxui:ReactiveContentPage
    x:Class="ReactiveUI.Samples.Maui.LoginPage"
    x:TypeArguments="local:LoginViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:rxui="clr-namespace:ReactiveUI.Maui;assembly=ReactiveUI.Maui"
    xmlns:local="clr-namespace:ReactiveUI.Samples.Maui"
    Title="Login">

    <VerticalStackLayout Padding="30" Spacing="16" VerticalOptions="Center">

        <Entry x:Name="Username" Placeholder="Username" />
        <Entry x:Name="Password" Placeholder="Password" IsPassword="True" />

        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
            <Button x:Name="CancelButton" Text="Cancel" Grid.Column="0" />
            <Button x:Name="LoginButton" Text="Login" Grid.Column="1" BackgroundColor="{StaticResource Primary}" TextColor="White" />
        </Grid>

    </VerticalStackLayout>

</rxui:ReactiveContentPage>
