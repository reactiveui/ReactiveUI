<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!-- Lean WPF leaf: compiles the shared WPF source (ReactiveUI.Wpf.Shared) against the lean ReactiveUI
         (RxVoid = ReactiveUI.Primitives.RxVoid). The .Reactive sibling recompiles the same source against
         System.Reactive's Unit. -->
    <TargetFrameworks>$(ReactiveUIWindowsOnlyTargets)</TargetFrameworks>
    <PackageDescription>Contains the ReactiveUI platform specific extensions for Windows Presentation Foundation (WPF)</PackageDescription>
    <PackageId>ReactiveUI.WPF</PackageId>
    <UseWpf>true</UseWpf>
    <PackageTags>mvvm;reactiveui;rx;reactive extensions;observable;LINQ;events;frp;wpf;net;netframework;netcore</PackageTags>
    <IsAotCompatible>false</IsAotCompatible>
    <EnableTrimAnalyzer>false</EnableTrimAnalyzer>
    <EnableSingleFileAnalyzer>false</EnableSingleFileAnalyzer>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ReactiveUI.Primitives.Wpf"/>
    <ProjectReference Include="..\ReactiveUI\ReactiveUI.csproj"/>
  </ItemGroup>

  <!-- The shared WPF seam source, compiled here with the lean RxVoid identity. -->
  <ItemGroup>
    <Compile Include="..\ReactiveUI.Wpf.Shared\**\*.cs" Link="ReactiveUI.Wpf.Shared\%(RecursiveDir)%(Filename)%(Extension)"/>
  </ItemGroup>
  <!-- The shared source carries no per-file usings for the namespaces it shifts between leaves; the lean
       leaf imports the unshifted forms here. -->
  <ItemGroup>
    <Using Include="ReactiveUI"/>
    <Using Include="ReactiveUI.Internal"/>
    <Using Include="ReactiveUI.Builder"/>
    <Using Include="ReactiveUI.Interfaces"/>
    <Using Include="ReactiveUI.Primitives.Disposables"/>
  </ItemGroup>

  <!-- Internal plumbing + platform sinks compiled per-assembly (no IVT between shipping libs; internal so the
       per-leaf copies stay assembly-private). Multicast subjects come from the ReactiveUI.Primitives package
       (Signal&lt;T&gt;), so they are NOT recompiled here. -->
  <ItemGroup>
    <Compile Include="..\Shared\ArgumentValidation.cs" Link="Shared\ArgumentValidation.cs"/>
    <Compile Include="..\Shared\DelegateObserver.cs" Link="Shared\DelegateObserver.cs"/>
    <Compile Include="..\Shared\Platform\FromEventObservable.cs" Link="Shared\Platform\FromEventObservable.cs"/>
    <Compile Include="..\Shared\Platform\ObserveOnObservable.cs" Link="Shared\Platform\ObserveOnObservable.cs"/>
    <Compile Include="..\Shared\Platform\IdleTimeoutObservable.cs" Link="Shared\Platform\IdleTimeoutObservable.cs"/>
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="ReactiveUI.NonParallel.Tests"/>
    <InternalsVisibleTo Include="ReactiveUI.Wpf.Tests"/>
  </ItemGroup>
</Project>
