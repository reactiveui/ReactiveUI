<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>$(ReactiveUITestingUITargets)</TargetFrameworks>
    <OutputType>Exe</OutputType>
    <RootNamespace>ReactiveUI.Tests</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\ReactiveUI.Test.Utilities\ReactiveUI.Test.Utilities.csproj"/>
    <ProjectReference Include="..\ReactiveUI.TestGuiMocks\ReactiveUI.TestGuiMocks.csproj"/>
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="**\*.cs"/>
    <None Include="**\*.cs"/>
    <Compile Include="API\**\*.cs"/>
  </ItemGroup>
  
  <!-- UseWindowsForms adds implicit global usings for System.Windows.Forms and System.Drawing, which collide with the
       WPF control/image types these tests use. Remove them so WPF names resolve unambiguously. -->
  <ItemGroup>
    <Using Remove="System.Windows.Forms" />
    <Using Remove="System.Drawing" />
    <Using Include="ReactiveUI.Builder" />
  </ItemGroup>

  <Choose>
    <When Condition=" $(TargetFramework.EndsWith('-windows10.0.19041.0')) ">
      <PropertyGroup>
        <UseWpf>true</UseWpf>
        <UseWindowsForms>true</UseWindowsForms>
      </PropertyGroup>
      <ItemGroup>
        <ProjectReference Include="..\..\ReactiveUI.Wpf\ReactiveUI.Wpf.csproj"/>
        <ProjectReference Include="..\..\ReactiveUI.Blend\ReactiveUI.Blend.csproj"/>
        <Using Include="ReactiveUI.Blend"/>
        <Using Include="ReactiveUI.Wpf.Binding"/>
        <Compile Include="Wpf\**\*.cs"/>
        <Compile Include="Xaml\**\*.cs"/>
        <Compile Include="WhenAny\**\*.cs"/>
        <Compile Include="ReactiveObjects\**\*.cs"/>
        <Compile Include="Utilities\**\*.cs"/>
        <Compile Include="AssemblyHooks.cs"/>
        <Compile Include="AssemblyInfo.Parallel.cs"/>
        <Page Update="Wpf\Mocks\CanExecuteMock\CanExecuteExecutingView.xaml">
          <XamlRuntime>$(DefaultXamlRuntime)</XamlRuntime>
        </Page>
      </ItemGroup>
    </When>
  </Choose>

</Project>
