<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>$(ReactiveUITestingTargets)</TargetFrameworks>
    <OutputType>Exe</OutputType>
    <AssemblyName>ReactiveUI.Routing.Reactive.Tests</AssemblyName>
    <RootNamespace>ReactiveUI.Tests</RootNamespace>
    <IsTestProject>true</IsTestProject>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="DynamicData"/>
    <PackageReference Include="Microsoft.Reactive.Testing"/>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\ReactiveUI.Routing.Reactive\ReactiveUI.Routing.Reactive.csproj"/>
    <!-- Test.Utilities is referenced as a project (as in the lean ReactiveUI.Routing.Tests), not cross-included.
         The DynamicData routing tests use none of its seam-sensitive helpers, and recompiling its source here
         would re-bind internal helpers (RxAppBuilder.ResetForTesting, SuspensionHostExtensions.*) against this
         assembly, which is outside the engine InternalsVisibleTo grant. -->
    <ProjectReference Include="..\ReactiveUI.Test.Utilities\ReactiveUI.Test.Utilities.csproj"/>
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\ReactiveUI.Routing.Tests\**\*.cs" Exclude="..\ReactiveUI.Routing.Tests\obj\**\*.cs;..\ReactiveUI.Routing.Tests\bin\**\*.cs" Link="ReactiveUI.Routing.Tests\%(RecursiveDir)%(Filename)%(Extension)"/>
  </ItemGroup>
</Project>
