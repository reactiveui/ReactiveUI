<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>$(ReactiveUITestingTargets)</TargetFrameworks>
    <IsTestProject>false</IsTestProject>
    <IsPackable>false</IsPackable>
    <RootNamespace>ReactiveUI.Tests.Utilities</RootNamespace>
    <PackageDescription>Shared test utilities for ReactiveUI test projects</PackageDescription>
  </PropertyGroup>

  <ItemGroup>
    <!-- System.Reactive is needed only for the VirtualTimeScheduler dual (ISequencer + IScheduler) impl that
         serves the .Reactive test leaves. PrivateAssets=all keeps it from flowing to consumers, so lean test
         projects stay System.Reactive-free (no System.ObservableExtensions.Subscribe ambiguity with the
         Primitives SubscribeExtensions). .Reactive consumers reference System.Reactive via their own seam. -->
    <PackageReference Include="System.Reactive" PrivateAssets="all"/>
    <PackageReference Include="TUnit.Core"/>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\ReactiveUI\ReactiveUI.csproj"/>
  </ItemGroup>

</Project>
