<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>$(ReactiveUIFinalTargetFrameworks)</TargetFrameworks>
    <AssemblyName>ReactiveUI</AssemblyName>
    <RootNamespace>ReactiveUI</RootNamespace>
    <PackageDescription>A MVVM framework that integrates with the Reactive Extensions for .NET to create elegant, testable User Interfaces that run on any mobile or desktop platform. This is the base package with the base platform implementations</PackageDescription>
    <PackageId>ReactiveUI</PackageId>
    <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios'">15.0</SupportedOSPlatformVersion>
    <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'maccatalyst'">15.0</SupportedOSPlatformVersion>
    <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'">35.0</SupportedOSPlatformVersion>
    <SupportedOSPlatformVersion Condition="$([System.String]::Copy('$(TargetFramework)').EndsWith('-windows10.0.19041.0'))">10.0.19041.0</SupportedOSPlatformVersion>
    <TargetPlatformMinVersion Condition="$([System.String]::Copy('$(TargetFramework)').EndsWith('-windows10.0.19041.0'))">10.0.19041.0</TargetPlatformMinVersion>
  </PropertyGroup>
  <!-- Neutral (non-seam) namespaces the recompiled/shared source uses; the seam set lives in ReactiveShim.props. -->
  <ItemGroup>
    <Using Include="ReactiveUI.Primitives.Disposables"/>
  </ItemGroup>
  <PropertyGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows'">
    <WindowsSdkPackageVersion Condition="$([System.String]::Copy('$(TargetFramework)').EndsWith('-windows10.0.19041.0'))">10.0.19041.57</WindowsSdkPackageVersion>
    <DefineConstants>$(DefineConstants);WINUI_TARGET</DefineConstants>
  </PropertyGroup>
  <PropertyGroup Condition="$(TargetFramework.StartsWith('net8.0')) or $(TargetFramework.StartsWith('net9.0')) or $(TargetFramework.StartsWith('net10.0')) or $(TargetFramework.StartsWith('net11.0'))">
    <IsAotCompatible>true</IsAotCompatible>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="Platforms\**\*.cs"/>
    <Compile Remove="Resources\**"/>
    <None Include="Platforms\**\*.cs"/>
    <EmbeddedResource Remove="Resources\**"/>
    <None Remove="Resources\**"/>
  </ItemGroup>
  <!-- Lean leaf: the type-agnostic core comes from ReactiveUI.Core (referenced), and the seam (RxVoid)
       source from ReactiveUI.Shared (compiled here with the lean RxVoid identity). The src/Shared root
       helpers (ArgumentExceptionHelper/DelegateObserver/EventPatternObservable) now live in Core and reach
       this assembly via the Core reference + IVT; multicast subjects come from the ReactiveUI.Primitives package. -->
  <ItemGroup>
    <ProjectReference Include="..\ReactiveUI.Core\ReactiveUI.Core.csproj"/>
  </ItemGroup>
  <ItemGroup>
    <Compile Include="..\ReactiveUI.Shared\**\*.cs" Link="ReactiveUI.Shared\%(RecursiveDir)%(Filename)%(Extension)"/>
  </ItemGroup>
  <!-- Internal plumbing helpers from src/Shared used by the seam source: each leaf compiles its own
       internal copy (Core has its own; internal keeps them assembly-private, so no cross-assembly clash). -->
  <ItemGroup>
    <Compile Include="..\Shared\ArgumentValidation.cs" Link="Shared\ArgumentValidation.cs"/>
    <Compile Include="..\Shared\DelegateObserver.cs" Link="Shared\DelegateObserver.cs"/>
  </ItemGroup>
  <!-- Shared source carries no per-file usings for the namespaces it shifts between leaves; the lean leaf
       imports them globally here (unshifted). The .Reactive leaf imports the shifted forms (Directory.Build.props). -->
  <ItemGroup>
    <Using Include="ReactiveUI"/>
    <Using Include="ReactiveUI.Internal"/>
    <Using Include="ReactiveUI.Builder"/>
    <Using Include="ReactiveUI.Interfaces"/>
  </ItemGroup>
  <ItemGroup Condition="$(TargetFramework.StartsWith('netstandard'))">
    <Compile Include="Platforms\netstandard2.0\**\*.cs"/>
    <Compile Include="Platforms\shared\**\*.cs"/>
  </ItemGroup>

  <ItemGroup Condition="$(TargetFramework.StartsWith('netstandard')) or $(TargetFramework.StartsWith('net4'))">
    <PackageReference Include="System.ComponentModel.Annotations"/>
    <PackageReference Include="System.Text.Json"/>
  </ItemGroup>

  <ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios' or $([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'maccatalyst'">
    <Compile Include="Platforms\apple-common\**\*.cs"/>
    <Compile Include="Platforms\ios\**\*.cs"/>
    <Compile Include="Platforms\uikit-common\**\*.cs"/>
    <Compile Include="Platforms\mobile-common\**\*.cs"/>
  </ItemGroup>
  <ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'macos'">
    <Compile Include="Platforms\apple-common\**\*.cs"/>
    <Compile Include="Platforms\mac\**\*.cs"/>
    <Compile Include="Platforms\mobile-common\**\*.cs"/>
  </ItemGroup>
  <ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'tvos'">
    <Compile Include="Platforms\apple-common\**\*.cs"/>
    <Compile Include="Platforms\tvos\**\*.cs"/>
    <Compile Include="Platforms\uikit-common\**\*.cs"/>
    <Compile Include="Platforms\mobile-common\**\*.cs"/>
  </ItemGroup>
  <!-- Apple Platforms reuse the platform-lib-only fused sinks from Shared\Platform (excluded from the core compile above). -->
  <ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios' or $([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'maccatalyst' or $([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'macos' or $([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'tvos'">
    <Compile Include="..\Shared\Platform\FromEventObservable.cs" Link="Shared\Platform\FromEventObservable.cs"/>
    <Compile Include="..\Shared\Platform\EventPatternObservable.cs" Link="Shared\Platform\EventPatternObservable.cs"/>
  </ItemGroup>
  <ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'">
    <Compile Include="Platforms\android\**\*.cs"/>
    <Compile Include="Platforms\mobile-common\**\*.cs"/>
    <!-- Android reuses the platform-lib-only fused sink from Shared\Platform (excluded from the core compile above). -->
    <Compile Include="..\Shared\Platform\EventPatternObservable.cs" Link="Shared\Platform\EventPatternObservable.cs"/>
  </ItemGroup>
  <ItemGroup Condition=" $(TargetFramework.StartsWith('net4')) or '$(TargetFramework)' == 'net11.0' or '$(TargetFramework)' == 'net10.0' or '$(TargetFramework)' == 'net9.0' or '$(TargetFramework)' == 'net8.0' or $(TargetFramework.EndsWith('-windows10.0.17763.0')) or $(TargetFramework.EndsWith('-windows10.0.19041.0')) ">
    <Compile Include="Platforms\net\**\*.cs"/>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="ReactiveUI.Primitives" ExcludeAssets="analyzers" />
    <PackageReference Include="Splat" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="ReactiveUI.Tests"/>
    <InternalsVisibleTo Include="ReactiveUI.Test.Utilities"/>
    <InternalsVisibleTo Include="ReactiveUI.TestGuiMocks"/>
    <InternalsVisibleTo Include="ReactiveUI.NonParallel.Tests"/>
    <InternalsVisibleTo Include="ReactiveUI.Wpf.Tests"/>
    <InternalsVisibleTo Include="ReactiveUI.WinForms.Tests"/>
    <InternalsVisibleTo Include="ReactiveUI.Uno"/>
    <InternalsVisibleTo Include="ReactiveUI.Uno.WinUI"/>
    <InternalsVisibleTo Include="ReactiveUI.Builder.Tests"/>
    <InternalsVisibleTo Include="ReactiveUI.AOT.Tests"/>
    <InternalsVisibleTo Include="ReactiveUI.Maui.Tests"/>
    <InternalsVisibleTo Include="ReactiveUI.Avalonia"/>
  </ItemGroup>
</Project>
