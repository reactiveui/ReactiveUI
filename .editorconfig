dotnet_diagnostic.SST1627.severity = error # Documentation text should not be empty
dotnet_diagnostic.SST1628.severity = error # Documentation text should begin with a capital letter
dotnet_diagnostic.SST1629.severity = error # Documentation text should end with a period
